[Unit]
Description=Tester Issue Logger API
After=network.target

[Service]
Type=simple
User=testerissues
Group=testerissues
WorkingDirectory=/opt/tester-issues/app
EnvironmentFile=/etc/tester-issues.env
ExecStart=/opt/tester-issues/app/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8010 --workers 1
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

